# Zonas marcadas para ETH — actualizado 2026-06-12 (precio de marca: 1666)
# Úsalo así:  source scripts/zonas.env && MANUAL_LEVELS="$ZONAS" ./scripts/monitor_labels.sh
# El monitor avisa cuando el precio se acerca o rompe cualquiera de estos niveles.

# Resistencias (arriba del precio) y soportes (abajo), ordenados de menor a mayor:
#   1653.5  soporte FUERTE (confluencia 15m+1h, 5 toques) — piso del rango
#   1664.4  soporte cercano (1h)
#   1669.0  resistencia inmediata (6 toques 15m) — la valla a vencer para largos
#   1672.7  resistencia intermedia
#   1678.5  resistencia (5 toques 15m)
#   1682.8  resistencia FUERTE (confluencia 15m+1h)
#   1692.3  techo del rango (1h)
#   1615.0  soporte mayor (1h) — invalidación de estructura

export ZONAS="1653.5,1664.4,1669.0,1672.7,1678.5,1682.8,1692.3,1615.0"
